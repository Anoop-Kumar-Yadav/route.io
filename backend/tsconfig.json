{
  "compilerOptions": {
    "target": "es6",
    "rootDir": "./src",
    "module": "commonjs",
    "paths": {
      "@/*": ["./src/*"]
    },
    "outDir": "./dist",
    "removeComments": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,

    "typeRoots": ["./@types", "./node_modules/@types"]
    // "typeRoots": ["./node_modules/@types", "./src/@types/express/index.d.ts"]
  },
  "ts-node": {
    "files": true
  },
  "include": ["./src/**/*", "@types"],
  "exclude": ["node_modules"]
}
